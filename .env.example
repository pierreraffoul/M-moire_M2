# ============================================================
# GitHubAuditBench — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS committer .env dans git.
# ============================================================

# Clé API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Token GitHub avec scopes : repo (read), security_events (read)
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Optionnel : override du modèle par défaut
# DEFAULT_MODEL=claude-sonnet-4-5
# JUDGE_MODEL=claude-opus-4-5

# Optionnel : plafond budget en USD (défaut 100.0)
# MAX_BUDGET_USD=100.0
